{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/sepay-webhook", "dest": "/api/sepay-webhook.js" },
    { "src": "/api/lemonsqueezy-webhook", "dest": "/api/lemonsqueezy-webhook.js" },
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/api/sync-user", "dest": "/api/sync-user.js" },
    { "src": "/api/use-credit", "dest": "/api/use-credit.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}